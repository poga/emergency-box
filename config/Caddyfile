{
	admin off
	auto_https off
	persist_config off
}

http://:{$EBOX_HTTP_PORT:80} {
	log

	route {
		handle /joinapi {
			rewrite * /join
			reverse_proxy 127.0.0.1:{$EBOX_JOIND_PORT:8081}
		}
		handle /join* {
			root * {$EBOX_ROOT:/opt/emergency-box}/landing
			rewrite * /index.html
			file_server
		}
		handle / {
			root * {$EBOX_ROOT:/opt/emergency-box}/landing
			rewrite * /welcome.html
			file_server
		}
		reverse_proxy 127.0.0.1:{$EBOX_CHATTO_PORT:8080}
	}
}
